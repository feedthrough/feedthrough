{
  "name": "@feedthrough/sveltekit",
  "version": "0.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feedthrough/feedthrough.git",
    "directory": "packages/sveltekit"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/embed-bundle.mjs",
    "build": "tsc",
    "dev": "node scripts/embed-bundle.mjs && tsc --watch",
    "typecheck": "node scripts/embed-bundle.mjs && tsc --noEmit"
  },
  "dependencies": {
    "@feedthrough/core": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@sveltejs/kit": ">=2.0"
  }
}
