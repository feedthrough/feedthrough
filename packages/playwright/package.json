{
  "name": "@feedthrough/playwright",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "prebuild": "node scripts/embed-bundle.mjs",
    "build": "tsc",
    "dev": "node scripts/embed-bundle.mjs && tsc --watch",
    "typecheck": "node scripts/embed-bundle.mjs && tsc --noEmit"
  },
  "dependencies": {
    "@feedthrough/core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40"
  }
}
