---
---

<section id="quick-start">
  <div class="container">
    <p class="section-label">Quick start</p>
    <h2>Up in four steps</h2>
    <p class="section-sub">No config files, no separate browser to launch.</p>
    <div class="steps fade">

      <div class="step">
        <div class="num">1</div>
        <div class="body">
          <h3>Add to your MCP client config</h3>
          <pre><span class="cm">// .claude/settings.json (Claude Code example)</span>
{'{'}
  <span class="str">"mcpServers"</span>: {'{'}
    <span class="str">"feedthrough"</span>: {'{'}
      <span class="str">"command"</span>: <span class="str">"npx"</span>,
      <span class="str">"args"</span>: [<span class="str">"@feedthrough/mcp"</span>]
    {'}'}
  {'}'}
{'}'}</pre>
        </div>
      </div>

      <div class="step">
        <div class="num">2</div>
        <div class="body">
          <h3>Inject the bridge into your app</h3>
          <p><strong>Eight first-party adapters</strong> — Vite, Next.js, Nuxt, SvelteKit, Remix, webpack, Cypress, Playwright. Pick yours, drop in one line. Dev only, zero cost in production.</p>

          <div class="fw-tabs">
            <button class="fw-tab active" data-fw="vite">Vite</button>
            <button class="fw-tab" data-fw="nextjs">Next.js</button>
            <button class="fw-tab" data-fw="nuxt">Nuxt</button>
            <button class="fw-tab" data-fw="sveltekit">SvelteKit</button>
            <button class="fw-tab" data-fw="remix">Remix</button>
            <button class="fw-tab" data-fw="webpack">webpack</button>
            <button class="fw-tab" data-fw="cypress">Cypress</button>
            <button class="fw-tab" data-fw="playwright">Playwright</button>
          </div>

          <p class="install-line">
            Install: <code class="install-pkg"></code>
            <a class="install-npm" href="https://www.npmjs.com/package/@feedthrough/vite" target="_blank" rel="noopener">npm ↗</a>
          </p>

          <div class="fw-snippet" data-fw="vite">
            <pre><span class="cm">// vite.config.ts</span>
<span class="kw">import</span> {'{'} feedthrough {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/vite"</span>;
<span class="fn">defineConfig</span>({'{'} plugins: [<span class="fn">feedthrough</span>()] {'}'});</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="nextjs">
            <pre><span class="cm">// next.config.ts</span>
<span class="kw">import</span> {'{'} withFeedthrough {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/nextjs"</span>;
<span class="kw">export default</span> <span class="fn">withFeedthrough</span>()({'{'} <span class="cm">/* your next config */</span> {'}'});</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="nuxt">
            <pre><span class="cm">// nuxt.config.ts</span>
<span class="kw">export default</span> <span class="fn">defineNuxtConfig</span>({'{'}
  modules: [<span class="str">"@feedthrough/nuxt"</span>],
{'}'});</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="sveltekit">
            <pre><span class="cm">// src/hooks.server.ts</span>
<span class="kw">import</span> {'{'} feedthroughHandle {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/sveltekit"</span>;
<span class="kw">import</span> {'{'} sequence {'}'} <span class="kw">from</span> <span class="str">"@sveltejs/kit/hooks"</span>;
<span class="kw">export const</span> handle = <span class="fn">sequence</span>(feedthroughHandle);</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="remix">
            <pre><span class="cm">// vite.config.ts</span>
<span class="kw">import</span> {'{'} feedthrough {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/remix"</span>;
<span class="fn">defineConfig</span>({'{'} plugins: [<span class="fn">remix</span>(), <span class="fn">feedthrough</span>()] {'}'});</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="webpack">
            <pre><span class="cm">// webpack.config.mjs</span>
<span class="kw">import</span> {'{'} FeedthroughPlugin {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/webpack"</span>;
<span class="kw">export default</span> {'{'} plugins: [<span class="kw">new</span> <span class="fn">FeedthroughPlugin</span>()] {'}'};</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="cypress">
            <pre><span class="cm">// cypress/support/e2e.ts</span>
<span class="kw">import</span> {'{'} setupFeedthrough {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/cypress"</span>;
<span class="fn">setupFeedthrough</span>();</pre>
          </div>

          <div class="fw-snippet hidden" data-fw="playwright">
            <pre><span class="cm">// Import test from the adapter instead of @playwright/test</span>
<span class="kw">import</span> {'{'} test, expect {'}'} <span class="kw">from</span> <span class="str">"@feedthrough/playwright"</span>;</pre>
          </div>

        </div>
      </div>

      <div class="step">
        <div class="num">3</div>
        <div class="body">
          <h3>Open your app in the browser</h3>
          <p>Once the bridge connects you'll see:</p>
          <pre><span class="connected">[feedthrough] browser connected</span></pre>
        </div>
      </div>

      <div class="step">
        <div class="num">4</div>
        <div class="body">
          <h3>Ask your AI agent what's wrong</h3>
          <pre><span class="cm">&gt; Why is the counter showing the wrong number?</span>

<span class="acc">Agent:</span> I'll check the console logs and inspect the element.

  get_console_logs()         <span class="cm">→ total: 1, 2, 3</span>
  inspect_element("#count")  <span class="cm">→ textContent: "2, 4, 6"</span>

  State increments by 2 but logs show +1.
  Bug on line 47: <span class="str">setViews(views + 2)</span></pre>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const PKG: Record<string, string> = {
    vite:       "@feedthrough/vite",
    nextjs:     "@feedthrough/nextjs",
    nuxt:       "@feedthrough/nuxt",
    sveltekit:  "@feedthrough/sveltekit",
    remix:      "@feedthrough/remix",
    webpack:    "@feedthrough/webpack",
    cypress:    "@feedthrough/cypress",
    playwright: "@feedthrough/playwright",
  };

  const tabs     = document.querySelectorAll<HTMLButtonElement>(".fw-tab");
  const snippets = document.querySelectorAll<HTMLElement>(".fw-snippet");
  const pkgCode  = document.querySelector<HTMLElement>(".install-pkg");
  const pkgLink  = document.querySelector<HTMLAnchorElement>(".install-npm");

  function activate(fw: string) {
    tabs.forEach(t => t.classList.toggle("active", t.dataset.fw === fw));
    snippets.forEach(s => s.classList.toggle("hidden", s.dataset.fw !== fw));
    if (pkgCode) pkgCode.textContent = `npm i -D ${PKG[fw]}`;
    if (pkgLink) pkgLink.href = `https://www.npmjs.com/package/${PKG[fw]}`;
  }

  tabs.forEach(tab => tab.addEventListener("click", () => activate(tab.dataset.fw!)));
  activate("vite");
</script>

<style>
  .steps { display: flex; flex-direction: column; gap: 32px; }
  .step  { display: grid; grid-template-columns: 32px 1fr; gap: 20px; }

  .num {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    background: var(--accent-soft); border: 1px solid rgba(34,211,238,0.3);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); font-weight: 600;
  }
  .body h3 { font-size: 0.9375rem; font-weight: 600; margin-bottom: 8px; }
  .body p  { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 12px; }
  .body p strong { color: var(--text); font-weight: 600; }

  .fw-tabs {
    display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px;
  }
  .fw-tab {
    padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 500;
    border: 1px solid var(--border); background: transparent;
    color: var(--text-muted); cursor: pointer; font-family: var(--font-mono);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .fw-tab:hover { color: var(--text); border-color: var(--text-dim); }
  .fw-tab.active {
    color: var(--accent); border-color: rgba(34,211,238,0.4);
    background: var(--accent-soft);
  }

  .fw-snippet.hidden { display: none; }

  .install-line {
    font-size: 0.8125rem; color: var(--text-muted);
    margin-bottom: 12px; display: flex; align-items: center; gap: 8px;
  }
  .install-line code { color: var(--text); }
  .install-npm { font-size: 0.75rem; color: var(--accent); white-space: nowrap; }

  .connected { color: var(--green); }
  .acc { color: var(--accent); }
</style>
