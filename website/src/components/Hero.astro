---
const GITHUB = "https://github.com/feedthrough/feedthrough";
---

<div class="hero">
  <div class="container">
    <div class="eyebrow">
      <span class="dot"></span>
      MCP Server
    </div>
    <h1>Debug any web app<br>with AI. <em>From inside.</em></h1>
    <p class="sub">
      Feedthrough injects a lightweight bridge into any running page and exposes DOM state,
      console logs, and network requests as MCP tools — so any AI agent can inspect and drive
      your app in real time.
    </p>
    <button class="install-block" onclick="copyInstall(this)">
      <code><span class="prompt">$</span> <span class="cmd">npm install</span> <span class="pkg">@feedthrough/mcp</span></code>
      <span class="copy-icon">⎘</span>
    </button>
    <div class="actions">
      <a href="#quick-start" class="btn-primary">Get started →</a>
      <a href={GITHUB} class="btn-secondary" target="_blank" rel="noopener">View on GitHub ↗</a>
    </div>
  </div>
</div>

<script>
  function copyInstall(el: HTMLElement) {
    navigator.clipboard.writeText("npm install @feedthrough/mcp").then(() => {
      const icon = el.querySelector(".copy-icon")!;
      icon.textContent = "✓";
      setTimeout(() => (icon.textContent = "⎘"), 1500);
    });
  }
  (window as any).copyInstall = copyInstall;
</script>

<style>
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .hero {
    padding: 120px 0 96px;
    background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(34,211,238,0.07) 0%, transparent 70%);
  }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 4px 12px; border-radius: 999px;
    border: 1px solid rgba(34,211,238,0.25); background: var(--accent-soft);
    font-size: 0.75rem; font-weight: 500; color: var(--accent);
    margin-bottom: 28px; letter-spacing: 0.05em; text-transform: uppercase;
  }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 700;
    letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 20px;
  }
  h1 em { font-style: normal; color: var(--accent); }
  .sub { font-size: 1.125rem; color: var(--text-muted); max-width: 520px; margin-bottom: 40px; }

  .install-block {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 10px 16px; border-radius: 8px;
    border: 1px solid var(--border); background: var(--bg-code);
    margin-bottom: 36px; cursor: pointer;
    transition: border-color 0.15s;
    font-family: inherit; font-size: inherit;
  }
  .install-block:hover { border-color: var(--accent); }
  .prompt { color: var(--text-dim); }
  .cmd { color: var(--text); }
  .pkg { color: var(--accent); }
  .copy-icon { color: var(--text-dim); font-size: 0.8rem; transition: color 0.15s; }
  .install-block:hover .copy-icon { color: var(--accent); }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 8px; font-size: 0.9375rem; font-weight: 600;
    background: var(--accent); color: #09090b; transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; text-decoration: none; }
  .btn-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 8px; font-size: 0.9375rem; font-weight: 500;
    border: 1px solid var(--border); color: var(--text-muted); background: var(--bg-card);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--text); text-decoration: none; }
</style>
