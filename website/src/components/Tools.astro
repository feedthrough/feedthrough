---
import { tools } from "../data/tools";
---

<section>
  <div class="container">
    <p class="section-label">MCP Tools</p>
    <h2>Thirteen tools, everything you need</h2>
    <p class="section-sub">Observe, interact, and preview live fixes — all the moment a browser connects.</p>
    <div class="grid fade">
      {tools.map(t => (
        <a class="card" href={`/tools#${t.id}`}>
          <div class="name">{t.name}</div>
          <div class="desc">{t.short}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
  .card {
    display: block;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .card:hover { border-color: rgba(34,211,238,0.4); text-decoration: none; }
  .name {
    font-family: var(--font-mono); font-size: 0.8rem;
    color: var(--accent); margin-bottom: 4px;
    display: flex; align-items: center; gap: 8px;
  }
  .desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }
</style>
