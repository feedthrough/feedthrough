---
const tools = [
  { name: "get_instructions()",            desc: "Usage guide — recommended workflow and selector tips" },
  { name: "click(selector)",               desc: "Click any element by CSS selector" },
  { name: "fill(selector, value)",          desc: "Type into an input, fires input + change events" },
  { name: "hover(selector)",               desc: "Trigger mouseover / mouseenter" },
  { name: "inspect_element(selector)",     desc: "Tag, classes, attributes, bounding rect, computed styles" },
  { name: "query_dom(selector)",           desc: "All elements matching a selector, summarised" },
  { name: "get_console_logs(limit?)",      desc: "Console output captured since the bridge connected" },
  { name: "get_network_requests(filter?)", desc: "Fetch + XHR with URLs, methods, and status codes" },
  { name: "screenshot()",                  desc: "Page screenshot", soon: true },
  { name: "connection_status()",           desc: "Check whether a browser is currently connected" },
];
---

<section>
  <div class="container">
    <p class="section-label">MCP Tools</p>
    <h2>Ten tools, everything you need</h2>
    <p class="section-sub">All tools are available the moment a browser connects.</p>
    <div class="grid fade">
      {tools.map(t => (
        <div class="card">
          <div class="name">{t.name}{t.soon && <span class="soon">soon</span>}</div>
          <div class="desc">{t.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
  .card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px;
    transition: border-color 0.15s;
  }
  .card:hover { border-color: rgba(34,211,238,0.4); }
  .name {
    font-family: var(--font-mono); font-size: 0.8rem;
    color: var(--accent); margin-bottom: 4px;
    display: flex; align-items: center; gap: 8px;
  }
  .soon {
    font-size: 0.65rem; font-family: var(--font-sans); font-weight: 600;
    letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--text-dim); border: 1px solid var(--border);
    border-radius: 4px; padding: 1px 5px;
  }
  .desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }
</style>
