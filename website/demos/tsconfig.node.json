{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "record/**/*.ts"]
}
